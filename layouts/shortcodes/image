{{ $src := .Get 0 }}
{{ $class := .Get 1 }}
{{ $caption := .Get 2 }}
<figure class="lightbox-image {{ $class }}">
  <a href="{{ $src }}" data-toggle="lightbox" data-gallery="page-gallery"{{ with $caption }} data-title="{{ . }}"{{ end }}>
    <img src="{{ $src }}" class="img-responsive" />
  </a>
  {{ with $caption }}<figcaption>{{ . }}</figcaption>{{ end }}
</figure>
